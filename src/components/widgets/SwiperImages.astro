---
import { Image } from 'astro:assets';
import type { ImagePath } from '~/types';
import { findImage } from '~/utils/images';
import { Swiper, SwiperWrapper, SwiperSlide, SwiperButtonPrev, SwiperButtonNext } from 'astro-swiper';
import { defaultSwiperOptions } from '~/utils/swiper-config';

export interface Props {
  images: ImagePath[];
}
const { images } = Astro.props;
---

<Swiper
    options={{
      ...defaultSwiperOptions,
      slidesPerView: 1,
      spaceBetween: 10,
      pagination: {
        clickable: true,
      },
      breakpoints: {
        640: {
          slidesPerView: 2,
          spaceBetween: 20,
        },
        1024: {
          slidesPerView: 3,
          spaceBetween: 20,
        },
      },
    }}
    class="p-5">
    <SwiperWrapper>
      {
        images.map(async (image: ImagePath) => {
          if (!image) return;
          const src = await findImage(image.src);
          if (!src) return;
          return (
            <SwiperSlide>
              <Image
                src={src}
                class="rounded-sm bg-gray-400 shadow-lg "
                widths={[400, 768]}
                sizes="(max-width: 767px) 400px, 768px"
                width={768}
                height={432}
                loading="eager"
                alt={image.alt || 'Image Hero'}
              />
            </SwiperSlide>
          );
        })
      }
    </SwiperWrapper>
    <SwiperButtonNext />
    <SwiperButtonPrev />
</Swiper>
