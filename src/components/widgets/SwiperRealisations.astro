---
import type { Realisation } from '~/types';
import GridItem from '../realisations/GridItem.astro';
import { Swiper, SwiperWrapper, SwiperSlide, SwiperButtonPrev, SwiperButtonNext } from 'astro-swiper';
import { defaultSwiperOptions } from '~/utils/swiper-config';

export interface Props {
  posts: Array<Realisation>;
}

const { posts } = Astro.props;
---

<div class="relative lg:px-8">
  <Swiper
    options={{
      ...defaultSwiperOptions,
      slidesPerView: 1,
      spaceBetween: 16,
      breakpoints: {
        1024: {
          slidesPerView: 2,
          spaceBetween: 20,
        },
        1280: {
          slidesPerView: 3,
          spaceBetween: 24,
        },
      },
    }}
    class="p-5">
      <SwiperWrapper class="items-stretch">
        {
          posts.map(async (post) => (
            <SwiperSlide class="flex h-auto">
              <GridItem post={post} />
            </SwiperSlide>
          ))
        }
      </SwiperWrapper>
  </Swiper>
  <SwiperButtonNext class="lg:-right-4!" />
  <SwiperButtonPrev class="lg:-left-4!" />
</div>

<style>
  .swiper-wrapper {
    align-items: stretch;
  }

  .swiper-slide {
    display: flex;
    height: auto;
  }

  .swiper-slide > :global(*) {
    width: 100%;
  }
</style>
