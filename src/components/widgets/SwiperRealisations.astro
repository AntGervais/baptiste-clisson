---
import type { Realisation } from '~/types';
import GridItem from '../realisations/GridItem.astro';

export interface Props {
  posts: Array<Realisation>;
}

const { posts } = Astro.props;
---

<div class="relative lg:px-8">
  <div class="swiper p-5">
    <div class="swiper-wrapper items-stretch">
      {
        posts.map(async (post) => (
          <div class="swiper-slide flex h-auto">
            <GridItem post={post} />
          </div>
        ))
      }
    </div>
  </div>
  <div class="swiper-button-next lg:-right-4!"></div>
  <div class="swiper-button-prev lg:-left-4!"></div>
</div>

<script>
  import { Swiper, Navigation, defaultSwiperOptions } from '~/utils/swiper-config';

  new Swiper('.swiper', {
    ...defaultSwiperOptions,
    slidesPerView: 1,
    spaceBetween: 16,
    modules: [Navigation],
    breakpoints: {
      1024: {
        slidesPerView: 2,
        spaceBetween: 20,
      },
      1280: {
        slidesPerView: 3,
        spaceBetween: 24,
      },
    },
  });
</script>

<style>
  .swiper-wrapper {
    align-items: stretch;
  }

  .swiper-slide {
    display: flex;
    height: auto;
  }

  .swiper-slide > :global(*) {
    width: 100%;
  }
</style>
