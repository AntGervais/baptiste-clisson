---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ToggleTheme from '~/components/common/ToggleTheme.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';

import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface ActionLink extends Link {
  type?: string;
}

interface MenuLink extends Link {
  links?: Array<Link>;
}

export interface Props {
  links?: Array<MenuLink>;
  actions?: Array<ActionLink>;
  isSticky?: boolean;
  showToggleTheme?: boolean;
  position?: string;
}

const { links = [], actions = [], isSticky = false, showToggleTheme = false, position = 'center' } = Astro.props;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky },
    'bg-primary text-beige top-0 z-40 mx-auto w-full flex-none px-3 py-3 transition-all duration-250 ease-in md:px-4 md:py-3.5',
  ]}
  id="header"
>
  <div class="mx-auto w-full max-w-6xl md:flex md:justify-between">
    <div class:list={[{ 'mr-auto': position === 'right' }, 'flex justify-between']}>
      <a class="flex items-center transition" href={getHomePermalink()} title="Accueil">
        <Logo />
      </a>
      <div class="flex hidden items-center">
        {showToggleTheme && <ToggleTheme />}
        <ToggleMenu />
      </div>
    </div>
    <nav
      class="font-heading hidden h-[calc(100vh-72px)] w-full items-center overflow-y-auto md:mx-5 md:flex md:h-auto md:w-auto md:overflow-visible"
      aria-label="Main navigation"
    >
      <ul class="flex w-full flex-col pt-8 text-xl md:w-auto md:flex-row md:self-center md:pt-0">
        {
          links.map(({ text, href, links }) => (
            <li class={links?.length ? 'dropdown' : ''}>
              {links?.length ? (
                <>
                  <button class="flex items-center px-4 py-3 font-medium transition duration-150 ease-in-out hover:text-gray-900">
                    {text} <Icon name="tabler:chevron-down" class="ml-0.5 hidden h-3.5 w-3.5 md:inline" />
                  </button>
                  <ul class="dropdown-menu rounded pl-4 font-medium drop-shadow-xl md:absolute md:hidden md:min-w-[200px] md:bg-white/90 md:pl-0 md:backdrop-blur-md">
                    {links.map(({ text: text2, href: href2 }) => (
                      <li>
                        <a
                          class="whitespace-no-wrap block px-5 py-2 first:rounded-t last:rounded-b md:hover:bg-gray-200"
                          href={href2}
                          title={text2}
                        >
                          {text2}
                        </a>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <a
                  class="flex items-center px-8 py-3 font-medium transition duration-150 ease-in-out hover:scale-105 hover:text-white md:px-4"
                  href={href}
                  title={text}
                >
                  {text}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
    <div class:list={[{ 'ml-auto': position === 'left' }, 'flex items-center md:mb-0 md:self-center']}>
      <div class="flex items-center">
        {showToggleTheme && <ToggleTheme iconClass="w-5 h-5" />}

        {
          actions?.length ? (
            <span class="ml-4">
              {actions.map(({ text, href, type, icon }) => (
                <a
                  class:list={[
                    'btn-tel btn bg-beige text-primary absolute top-3 right-2 ml-2 border-none px-5.5 py-2.5 text-sm transition duration-150 ease-in-out hover:scale-105 hover:bg-white md:relative md:top-auto md:right-auto md:px-6',
                    { 'btn-ghost': type === 'ghost', 'btn-primary': type === 'primary' },
                  ]}
                  href={href}
                  title="lien téléphone"
                >
                  {icon && <Icon name={icon} class="mr-1 inline-block h-4 w-4" />}
                  <Fragment set:html={text} />
                </a>
              ))}
            </span>
          ) : (
            ''
          )
        }
      </div>
    </div>
  </div>
</header>
