---
import { Image } from 'astro:assets';
import { findImage } from '~/utils/images';

const image = await findImage('/images/logo/BoisDebout-Creme.webp');
---

<Image
  src={image}
  class="logo block h-10 w-auto transition duration-250 ease-out lg:h-14"
  alt={'Bois Debout Logo'}
  loading="eager"
  fetchpriority="high"
  decoding="async"
/>
