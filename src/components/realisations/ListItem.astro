---
import { Image } from 'astro:assets';
import Tags from '~/components/realisations/Tags.astro';

import { REALISATIONS } from '~/config.mjs';
import type { Realisation } from '~/types';

import { getPermalink } from '~/utils/permalinks';
import { findImage } from '~/utils/images';

export interface Props {
  post: Realisation;
}

const { post } = Astro.props;
const image = await findImage(post.image);

const link = !REALISATIONS?.post?.disabled ? getPermalink(post.permalink, 'realisations') : '';
---

<article
  class={`max-w-md mx-auto md:max-w-none grid gap-6 transition duration-200 ease-out hoverable:-translate-y-1 md:gap-8
  ${image ? 'md:grid-cols-2' : ''}`}
>
  {
    image && (
      <a class="group relative block" href={link} title="Voir les photos">
        <div class="relative h-0 overflow-hidden rounded bg-gray-400 pb-[75%] shadow-lg">
          {image && (
            <Image
              src={image}
              class="absolute inset-0 mb-6 h-full w-full rounded bg-gray-400 object-cover shadow-lg"
              widths={[400, 900]}
              sizes="(max-width: 900px) 400px, 900px"
              alt={post.title || post.accroche || ''}
              width={900}
              height={675}
              loading="lazy"
              decoding="async"
            />
          )}
        </div>
      </a>
    )
  }
  <div class="flex flex-col justify-between">
    <header>
      <a href={link} title="Voir les détails">
        <h2 class="font-heading mb-2 text-xl leading-tight sm:text-2xl">
          {link ? <span class="hover:text-primary">{post.title}</span> : post.title}
        </h2>
      </a>
    </header>
    <section class="h-full">
      {post.accroche && <p class="text-muted text-lg">{post.accroche}</p>}
    </section>
    <footer class="">
      <div class="flex flex-nowrap items-center gap-4">
        <div class="flex min-w-0 flex-1 justify-start">
          <Tags tags={post.tags} />
        </div>
        <div class="flex shrink-0 justify-end">
          <a class="text-primary inline-flex items-center whitespace-nowrap" href={link} title="Voir les détails">
            Détails
            <svg
              class="ml-2 h-4 w-4"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14"></path>
              <path d="M12 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </footer>
  </div>
</article>
