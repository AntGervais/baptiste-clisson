---
import { getPermalink } from '~/utils/permalinks';

import { REALISATIONS } from '~/config.mjs';
import type { Realisation } from '~/types';

export interface Props {
  tags: Realisation['tags'];
  class?: string;
}

const { tags, class: className = 'text-base' } = Astro.props;
const containerClass = ['flex w-full flex-wrap justify-start gap-2 text-left', className].filter(Boolean).join(' ');
---

{
  tags && Array.isArray(tags) && (
    <div class={containerClass}>
      {tags.map(
        (tag) =>
          tag && (
            <div class="text-primary! hover:bg-accent! hoverable:scale-105 bg-primary/10! inline-flex items-center rounded-sm font-medium lowercase transition duration-200 ease-out hover:text-white!">
              {REALISATIONS?.tag?.disabled ? (
                tag
              ) : (
                <a class="block px-2.5 pt-[3px] pb-1 text-sm leading-none text-inherit! capitalize" href={getPermalink(tag, 'tag')} title={tag}>
                  {tag}
                </a>
              )}
            </div>
          )
      )}
    </div>
  )
}
