---
export interface Props {
  class?: string;
  reveal?: string;
  delay?: string | number;
  duration?: string;
  offset?: string;
  easing?: string;
  once?: boolean;
  [key: string]: any;
}

const { 
  class: className, 
  reveal, 
  delay,
  ...restProps 
} = Astro.props;

// Traduction des types de révélation vers nos classes CSS
const revealClass = 
  reveal === 'fade-left' ? 'reveal-left' : 
  reveal === 'fade-right' ? 'reveal-right' : 
  '';
---

<div 
  class:list={['reveal', revealClass, className]} 
  style={delay ? `--delay: ${delay}ms` : ''}
  data-reveal={reveal}
  data-reveal-delay={delay}
  {...restProps}
>
  <slot />
</div>
