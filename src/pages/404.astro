---
import Layout from '~/layouts/PageLayout.astro';
import { getHomePermalink } from '~/utils/permalinks';

const title = `Error 404`;
---

<Layout meta={{ title }}>
  <section class="flex min-h-[70dvh] items-center px-6 py-16">
    <div class="mx-auto flex max-w-lg flex-col items-center justify-center text-center">
      <p class="font-heading text-primary text-7xl md:text-8xl">
        <span class="sr-only">Erreur </span>404
      </p>
      <h1 class="font-heading text-secondary mt-4 mb-3 text-3xl md:text-4xl">Cette page n'existe pas</h1>
      <p class="text-muted mb-8 text-lg text-pretty">
        Le lien est peut-être ancien ou la page a été déplacée. Reprenons du bon pied.
      </p>
      <div class="flex flex-col gap-4 sm:flex-row">
        <a href={getHomePermalink()} class="btn btn-primary" title="Retour à l'accueil">Retour à l'accueil</a>
        <a href="tel:+33630481737" class="btn" title="Appeler Baptiste Clisson">Appeler Baptiste</a>
      </div>
    </div>
  </section>
</Layout>
